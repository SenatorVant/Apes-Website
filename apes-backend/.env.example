# ─────────────────────────────────────────────────
#  Apes of Wrath 668 — Backend Environment Config
# ─────────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env to git.
# ─────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development          # change to "production" on your server

# Security — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_to_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# Google OAuth
# Get these from https://console.cloud.google.com/
# Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs: http://YOUR_SERVER_IP:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Frontend URL (used for CORS and redirects after OAuth)
FRONTEND_URL=http://localhost:3000

# Database path (relative to project root)
DB_PATH=./data/teamOS.db

# File uploads
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Team domain — only this domain is allowed to log in
TEAM_DOMAIN=apesofwrath668.org
